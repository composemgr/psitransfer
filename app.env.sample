# PsiTransfer — environment variable reference
# Copy relevant lines to a .env file alongside docker-compose.yaml

# Timezone
TZ=America/New_York

# Hostname
BASE_HOST_NAME=${HOSTNAME}

# Admin password (for the /admin panel)
APP_ADMIN_PASS=changeme_admin_password

# Upload password (restrict who can upload files)
# Leave empty to allow unauthenticated uploads
UPLOAD_PASS=changeme_upload_password
